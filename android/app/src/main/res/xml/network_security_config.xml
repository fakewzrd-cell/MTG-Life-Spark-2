<?xml version="1.0" encoding="utf-8"?>
<!--
  LAN multiplayer uses plain ws:// WebSocket (no TLS on local network).
  Document this requirement in README before tightening further.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
